# Production backend environment
# Copy to backend/.env before: docker compose up -d --build

DJANGO_ENV=production
DEBUG=False
SECRET_KEY=replace-with-50-plus-character-random-secret-key

ALLOWED_HOSTS=your-domain.com,www.your-domain.com,backend
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# On Render web service, use the Internal Database URL from the Postgres dashboard.
DATABASE_URL=postgresql://apexcareir_user:replace-password@dpg-xxxxx-a/apexcareir
TIME_ZONE=Africa/Nairobi

FRONTEND_APP_URL=https://your-domain.com
FRONTEND_PASSWORD_RESET_URL=https://your-domain.com/admin1/reset-password
API_PUBLIC_URL=https://your-domain.com
BACKEND_PUBLIC_URL=https://your-domain.com

DEFAULT_FROM_EMAIL=apexcareir@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=apexcareir@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=True

# Enable after HTTPS is confirmed working behind nginx / load balancer
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# AI assistant — disable if Ollama is not available on the host
AI_USE_OLLAMA=False
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=45

LOG_LEVEL=INFO
