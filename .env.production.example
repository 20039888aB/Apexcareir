# Docker Compose / production deployment
# Copy to .env in the project root before: docker compose up -d --build

POSTGRES_DB=apexcareir_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password

# Public site URL (used for CORS, CSRF, email links, and PDF logo URLs)
APP_DOMAIN=https://your-domain.com
HTTP_PORT=80

# Frontend build arg — use /api/v1 when nginx proxies API on the same domain
VITE_API_BASE_URL=/api/v1
